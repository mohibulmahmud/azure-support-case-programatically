# ─────────────────────────────────────────────────────────────────────────────
# ticket.env — Configuration for create-azure-support-ticket.sh
#
# Usage:
#   ./create-azure-support-ticket.sh --config ticket.env
#   ./create-azure-support-ticket.sh --config ticket.env --dry-run --verbose
#
# Copy this file and customize per scenario. Do NOT commit with real emails.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ticket Details ───────────────────────────────────────────────────────────
TICKET_SERVICE="Azure Monitor"
TICKET_PROBLEM="migrating to Azure Monitor Agent"
TICKET_SEVERITY="minimal"                # minimal | moderate | highestcriticalimpact | critical
TICKET_TITLE="Automated Alert: Azure Monitor Metrics Gap"
TICKET_DESCRIPTION="Metrics for the production database are not appearing in the dashboard. Investigation needed for data collection pipeline."

# Uncomment to target a specific subscription (otherwise uses current)
# TICKET_SUBSCRIPTION="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ── Contact Information ──────────────────────────────────────────────────────
CONTACT_FIRST_NAME="First"
CONTACT_LAST_NAME="Last"
CONTACT_EMAIL="your-work-email@microsoft.com"
CONTACT_METHOD="email"                   # email | phone
CONTACT_TIMEZONE="Eastern Standard Time"
CONTACT_COUNTRY="CAN"
CONTACT_LANGUAGE="en-us"

# ── Diagnostic Consent (mandatory for technical cases) ───────────────────────
ADVANCED_DIAGNOSTIC_CONSENT="Yes"        # Yes | No
